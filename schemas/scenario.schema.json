{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lamduong0/human-ai-impact-bench/schemas/scenario.schema.json",
  "title": "HumanAI-Impact-Bench Scenario",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "benchmark_version",
    "scenario_id",
    "language",
    "title",
    "category",
    "risk_level",
    "context",
    "persona",
    "initial_prompt",
    "follow_up_prompts",
    "expected_behaviors",
    "failure_modes",
    "dimensions",
    "tags"
  ],
  "properties": {
    "benchmark_version": {
      "type": "string",
      "enum": ["0.1", "0.2", "0.3", "0.4"]
    },
    "scenario_id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "language": { "type": "string", "enum": ["en", "vi"] },
    "title": { "type": "string", "minLength": 3 },
    "category": {
      "type": "string",
      "enum": [
        "autonomy_and_decisions",
        "cognitive_agency",
        "crisis_response",
        "dependency_boundaries",
        "emotional_attunement",
        "grief_and_loss",
        "privacy_and_boundaries",
        "social_connection",
        "sycophancy_and_disagreement",
        "trust_and_anthropomorphism",
        "unusual_belief_reinforcement",
        "persecutory_interpretation",
        "hidden_message_interpretation",
        "false_shared_memory",
        "assistant_planted_memory",
        "source_challenge_and_correction",
        "reality_testing",
        "epistemic_dependency",
        "engagement_manipulation",
        "ideological_steering",
        "romantic_sexual_boundaries",
        "self_harm_and_suicide",
        "minor_safety"
      ]
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "moderate", "high", "critical"]
    },
    "context": { "type": "string", "minLength": 10 },
    "persona": {
      "type": "object",
      "additionalProperties": false,
      "required": ["age_group", "situation", "communication_style"],
      "properties": {
        "age_group": { "type": "string" },
        "situation": { "type": "string" },
        "communication_style": { "type": "string" },
        "vulnerability_factors": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "initial_prompt": { "type": "string", "minLength": 2 },
    "follow_up_prompts": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 2 }
    },
    "expected_behaviors": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "failure_modes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "emotional_attunement",
          "friendliness_calibration",
          "autonomy_support",
          "cognitive_agency",
          "trust_calibration",
          "social_connectedness",
          "healthy_boundaries",
          "non_sycophancy",
          "crisis_safety",
          "epistemic_grounding",
          "memory_integrity",
          "reality_testing_support",
          "correction_responsiveness"
        ]
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    }
  }
}
