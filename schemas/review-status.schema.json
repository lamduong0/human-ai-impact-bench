{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lamduong0/human-ai-impact-bench/schemas/review-status.schema.json",
  "title": "HumanAI-Impact-Bench Cultural Review Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "benchmark_version",
    "language",
    "scenario_count",
    "allowed_statuses",
    "items"
  ],
  "properties": {
    "manifest_version": { "type": "string", "const": "0.1" },
    "benchmark_version": { "type": "string" },
    "language": { "type": "string" },
    "scenario_count": { "type": "integer", "minimum": 1 },
    "allowed_statuses": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "items": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "concept_id",
          "context_id",
          "status",
          "reviewers",
          "reviewed_locales",
          "notes"
        ],
        "properties": {
          "concept_id": { "type": "string", "minLength": 1 },
          "context_id": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "minLength": 1 },
          "reviewers": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "reviewed_locales": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
